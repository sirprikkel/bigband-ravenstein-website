     <script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.11.4/jquery-ui.min.js"></script>
<script>
   $('.verhuurContent').hide();
   $(".verhuurimg").addClass( "small" );
   $(".verhuurimg").removeClass( "plus" );
     $(".verhuurbox").click(function(){
          $('.verhuurContent').hide();
          $(".verhuurimg.plus").addClass( "small" );
          $(".verhuurimg").removeClass( "plus" );
                     
                   
          var id1 = this.id;
          var id2 = "#"+id1+" .verhuurContent";
         $(id2).show();
         $("#"+id1+" .verhuurimg").removeClass( "small" );
         $("#"+id1+" .verhuurimg").addClass( "plus" );

         // alert(id2)
     });
     function sluitZoeken(){
          $('.site-header.zoeken').hide();
          $('.site-header.nav').show();
          $('.snelzoeken').hide();
     }
     function sluitZoekenMobiel(){
          $('.mobiel.zoeken').hide();
          $('.mobiel.nav').show();
          $('.snelzoeken').hide();
     }
     $('.mobiel.zoeken').hide();
     $('.site-header.zoeken').hide();
     $(".zoekknop").click(function() {
          $('.site-header.zoeken').show();
          $('.site-header.nav').hide();
          $('.snelzoeken').show();
          $('.mobiel.zoeken').show();
     });
     
     $(".navopen").click(function() {
          $('.mobiel-nav').slideToggle("fast");
          

     });
    
     
       
     function init() {
          window.addEventListener('scroll', function(e){
               var distanceY = window.pageYOffset || document.documentElement.scrollTop,
               shrinkOn = 30,
               header = document.querySelector("header");
               if (distanceY > shrinkOn) {
                    $('.site-header').addClass('sticky-header');
                    $('.snelzoeken').addClass('sticky-snelzoeken');
                    $("body").css({"margin-top":"96px"});
                    $("ul.rslides_tabs.rslides1_tabs").css({"top":"283px"});
               } else {
                    $('.sticky-snelzoeken').removeClass('sticky-snelzoeken');
                    $('.sticky-header').removeClass('sticky-header');
                    $("body").css({"margin-top":"0px"});
                    $("ul.rslides_tabs.rslides1_tabs").css({"top":"373px"});
               }
          });
     }
     window.onload = init();
  
     
     var wrap = $("header");
                   
if ( window.location.hash ) {
    var hash = window.location.hash,
        $hash = $(hash);
 
    $hash.removeAttr('id');
    $hash.before('<div id="'+hash.slice(1)+'" class="hashlink"></div>');
    window.location.hash = hash;


/* Captures click events on all anchor tag with a hash tag */
$(document).on('click', 'a[href^="#"]', function(event) {
  // Click events are captured before hashchanges. Timeout
  // causes offsetAnchor to be called after the page jump.
  window.setTimeout(function() {
    offsetAnchor();
  }, 0);
});

window.setTimeout(offsetAnchor, 0);
}
</script>


